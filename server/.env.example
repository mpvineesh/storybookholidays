PORT=5001
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority&appName=storybookholidays
CLIENT_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,https://storybookholidays-india.web.app,https://storybookholidays-india.firebaseapp.com
AWS_REGION=ap-south-1
S3_BUCKET_NAME=storybookholidays-package
AWS_ACCESS_KEY_ID=replace-with-your-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-your-secret-access-key
# Optional. If omitted, the backend uses
# https://<bucket>.s3.<region>.amazonaws.com
S3_PUBLIC_BASE_URL=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_TOKEN_SECRET=replace-with-a-long-random-secret
